# API base URL the client talks to. Inlined at BUILD time by Vite (not runtime).
# - dev/desktop: local API server
# - production web: your deployed API origin. The deploy image is built with
#   VITE_API_URL="https://insight-api.polytronx.com" (see .github/workflows/deploy.yml).
VITE_API_URL="http://localhost:5174"
