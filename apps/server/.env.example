# PostgreSQL (with pgvector extension)
DATABASE_URL="postgres://insightlibrary:insightlibrary@localhost:5432/insightlibrary"

# better-auth
BETTER_AUTH_SECRET="generate-a-long-random-string"
BETTER_AUTH_URL="http://localhost:5174"

# Web SPA origin allowed for CORS (production deploy of apps/app build:web)
WEB_ORIGIN="http://localhost:4173"

# Gemini — server-side only; NEVER ship this key in any client
GEMINI_API_KEY=""

# S3-compatible object storage (MinIO locally)
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="insightlibrary-documents"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
