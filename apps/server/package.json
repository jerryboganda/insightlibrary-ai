{
  "name": "@insightlibrary/server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 5174",
    "build": "vite build",
    "preview": "vite preview --port 5174",
    "start": "node build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "svelte-kit sync && vitest run",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/lib/server/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/lib/server/db/seed-runner.ts",
    "db:ontology": "tsx src/lib/server/ontology/seed-runner.ts",
    "db:ontology:load": "tsx src/lib/server/ontology/load-runner.ts",
    "ontology:build": "tsx scripts/ontology/build-obo.ts",
    "ontology:build:rrf": "tsx scripts/ontology/build-rrf.ts",
    "ontology:build:mesh": "tsx scripts/ontology/build-mesh.ts",
    "db:auth": "npx --yes @better-auth/cli@latest generate --config src/lib/server/auth-config.ts --output src/lib/server/db/auth-schema.ts -y",
    "worker": "tsx src/lib/server/jobs/worker.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@aws-sdk/client-s3": "^3.1079.0",
    "@aws-sdk/s3-request-presigner": "^3.1079.0",
    "@google/genai": "^2.10.0",
    "@insightlibrary/schemas": "workspace:*",
    "better-auth": "^1.6.0",
    "drizzle-orm": "^0.45.0",
    "jszip": "^3.10.1",
    "openai": "^6.45.0",
    "pg": "^8.13.0",
    "pg-boss": "^12.25.0",
    "tsx": "^4.19.0",
    "unpdf": "^1.4.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "catalog:",
    "@sveltejs/kit": "catalog:",
    "@sveltejs/vite-plugin-svelte": "catalog:",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.31.0",
    "svelte": "catalog:",
    "svelte-check": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "^3.2.0"
  }
}
