# Copy to .env on the VPS (/opt/insight/app/.env, chmod 600). Never commit .env.

# Public hosts (Cloudflare Tunnel terminates TLS; single-level subdomains only —
# CF free Universal SSL does not cover x.y.polytronx.com)
PUBLIC_API_HOST=insight-api.polytronx.com
S3_PUBLIC_HOST=https://insight-s3.polytronx.com

# Postgres (internal docker network only).
# PG_USER is the bootstrap SUPERUSER (admin/maintenance only — superusers
# bypass row-level security, so the app must never connect as it).
# APP_DB_USER is the NON-superuser role the app connects as; it is created by
# deploy/postgres-init/01-app-role.sh on first init and owns the database.
# DATABASE_URL must use APP_DB_USER — the services refuse to boot as a
# superuser/BYPASSRLS role.
PG_USER=insight
PG_PASSWORD=change-me
PG_DB=insight
APP_DB_USER=insight_app
APP_DB_PASSWORD=change-me-app
DATABASE_URL=postgres://insight_app:change-me-app@postgres:5432/insight

# Valkey / Redis (cache, queue, pub-sub)
REDIS_URL=redis://redis:6379

# MinIO (S3-compatible object store)
MINIO_ROOT_USER=insight
MINIO_ROOT_PASSWORD=change-me
# Optional: scoped service-account credentials for the app (create with
# `mc admin user svcacct add local insight`). When set, the services sign
# requests and presigned URLs with these instead of the root account.
#S3_ACCESS_KEY=
#S3_SECRET_KEY=
S3_ENDPOINT_INTERNAL=http://minio:9000
S3_ENDPOINT_PUBLIC=https://insight-s3.polytronx.com
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
S3_BUCKET_DOCS=documents
S3_BUCKET_FIGS=figures
S3_BUCKET_THUMBS=thumbs
S3_BUCKET_AUDIO=audio
S3_BUCKET_EXPORTS=exports

# Auth — JWTs issued by insight-api (argon2 passwords; OIDC deferred)
JWT_SECRET=change-me-generate-64-random-bytes
JWT_ACCESS_TTL_SECS=900
JWT_REFRESH_TTL_SECS=1209600
# Secure attribute on auth cookies; set false only for plain-http local stacks
COOKIE_SECURE=true

# API hardening
CORS_ORIGINS=http://localhost:5173,http://localhost:1420,https://insightai.polytronx.com
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW_SECS=60

# Side services
PARSER_SVC_URL=http://parser-svc:8000
INFERENCE_SVC_URL=http://inference-svc:8000

# Ingestion (Phase 4). PARSE_MAX_PAGES bounds parser memory; LOW_CONF_THRESHOLD
# marks blocks below this confidence as low_confidence for the coverage audit.
PARSE_MAX_PAGES=40
LOW_CONF_THRESHOLD=0.4

# Paid LLM providers (BYO; heavy reasoning runs on a paid API — no local LLM
# on this RAM-tight shared VPS)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Stripe (test mode until launch)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Logging
RUST_LOG=info
